# name: Breath Analysis
# description: Analyzes latent vectors for breath-based biomarkers
# version: 1.0.0
"""
Mock Breath Analysis Plugin for Osmograph as Example

Detects common breath biomarkers from e-nose latent vectors.
Drop this file (rename to .py) into the plugins folder.

Expected latent_vector shape: (256,)
"""
import numpy as np

# Simplified biomarker decision boundaries
# In production, these would come from a trained classifier
BIOMARKERS = {
    "acetone": {"threshold": 0.35, "suggested": "Dietary ketosis / diabetes screening"},
    "ammonia": {"threshold": 0.40, "suggested": "Renal function indicator"},
    "methanol": {"threshold": 0.30, "suggested": "Possible methanol exposure"},
    "ethanol": {"threshold": 0.25, "suggested": "Recent alcohol consumption"},
}


def run(latent_vector: np.ndarray) -> dict:
    """
    Analyze a 256-dim latent vector for breath biomarkers.

    Args:
        latent_vector: 256-dimensional numpy array from the encoder.

    Returns:
        dict with biomarker detections and confidence scores.
    """
    if latent_vector.shape != (256,):
        latent_vector = latent_vector.flatten()
        if latent_vector.shape[0] != 256:
            return {"error": f"Expected 256-dim vector, got {latent_vector.shape}"}

    activations = np.abs(latent_vector)
    norm_activations = activations / (activations.max() + 1e-8)

    results = {}
    for biomarker, spec in BIOMARKERS.items():
        regions = _get_biomarker_regions(biomarker)
        region_energy = norm_activations[regions].mean() if len(regions) > 0 else 0.0

        detected = region_energy > spec["threshold"]
        results[biomarker] = {
            "detected": bool(detected),
            "score": float(round(region_energy, 4)),
            "note": spec["suggested"] if detected else "Not detected",
        }

    # Health summary
    detected_any = any(v["detected"] for v in results.values())
    results["summary"] = (
        "Biomarkers detected — consider consulting a healthcare professional"
        if detected_any
        else "No significant biomarkers detected"
    )

    return results


def _get_biomarker_regions(biomarker: str) -> slice:
    """Return latent dimension index ranges associated with each biomarker."""
    regions = {
        "acetone": slice(40, 70),
        "ammonia": slice(70, 100),
        "methanol": slice(100, 130),
        "ethanol": slice(130, 160),
    }
    return regions.get(biomarker, slice(0, 10))
